# Opencast Meet Configuration
# Copy this file to .env and fill in your details.

# BigBlueButton server
BBB_SERVER_URL=https://your-bbb-server.com/bigbluebutton/
BBB_SERVER_SECRET=your-secret-key

# Meeting room configuration
BBB_MEETING_ID=opencast-meet
BBB_MEETING_NAME=Opencast Meeting
BBB_MUTE_ON_START=true
BBB_RECORD=true
BBB_AUTO_START_RECORDING=false
BBB_ALLOW_START_STOP_RECORDING=true
BBB_LOGIN_URL=https://meet.opencast.video
BBB_LOGOUT_URL=https://meet.opencast.video
BBB_WELCOME_MESSAGE=Welcome!
BBB_PRE_UPLOADED_PRESENTATION=

# Access passwords — set both before starting the server
APP_USER_PASSWORD=change-me-user
APP_MODERATOR_PASSWORD=change-me-moderator

# HTTP listen address (default: 127.0.0.1:8080)
APP_LISTEN_ADDR=127.0.0.1:8080

# Opencast integration (requires BBB_RECORD=true and the opencast-bigbluebutton-integration post-archive hook)
# OC_SERIES_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # UUID of the target Opencast series
# OC_DC_CREATOR=Jane Smith                             # Presenter name
# OC_ADD_WEBCAMS=true                                  # Include webcam recordings
# OC_ACL_READ_ROLES=ROLE_USER                          # Comma-separated roles with read access
# OC_ACL_WRITE_ROLES=ROLE_ADMIN                        # Comma-separated roles with write access
