# Opencast Meet Configuration
# Copy this file to .env and fill in your details.

# BigBlueButton server
BBB_SERVER_URL=https://your-bbb-server.com/bigbluebutton/
BBB_SERVER_SECRET=your-secret-key

# Meeting rooms
# Define rooms with ROOM_N_* variables (N = 1, 2, 3, …).
# When more than one room is configured, a dropdown appears on the login page.
ROOM_1_ID=opencast-meet
ROOM_1_NAME=Opencast Meeting
ROOM_1_APPEND_DATE=false
ROOM_1_RECORD=true
ROOM_1_AUTO_START_RECORDING=false
ROOM_1_ALLOW_START_STOP_RECORDING=true
ROOM_1_WELCOME_MESSAGE=Welcome!
ROOM_1_PRE_UPLOADED_PRESENTATION=
# ROOM_1_OC_SERIES=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # UUID of the target Opencast series
# ROOM_1_OC_DC_CREATOR=Jane Smith                         # Presenter name
# ROOM_1_OC_ADD_WEBCAMS=true                              # Include webcam recordings
# ROOM_1_OC_ACL_READ_ROLES=ROLE_USER                      # Comma-separated roles with read access
# ROOM_1_OC_ACL_WRITE_ROLES=ROLE_ADMIN                    # Comma-separated roles with write access

# Second room example:
# ROOM_2_ID=seminar-room
# ROOM_2_NAME=Seminar Room
# ROOM_2_RECORD=false
# ...

# Global BBB settings (apply to all rooms)
BBB_MUTE_ON_START=true
BBB_LOGIN_URL=https://meet.opencast.video
BBB_LOGOUT_URL=https://meet.opencast.video

# Access passwords — set both before starting the server
APP_USER_PASSWORD=change-me-user
APP_MODERATOR_PASSWORD=change-me-moderator

# HTTP listen address (default: 127.0.0.1:8080)
APP_LISTEN_ADDR=127.0.0.1:8080

# RealIP (Optional)
# Enable to extract client IP from X-Forwarded-For or X-Real-IP headers
# Set to true when running behind a trusted reverse proxy like Caddy
# ENABLE_REAL_IP=false

# Metrics Basic Auth (Optional)
# Protect the /metrics endpoint with HTTP Basic Auth.
# Both must be set together or both left empty.
# METRICS_USERNAME=prometheus
# METRICS_PASSWORD=secret
